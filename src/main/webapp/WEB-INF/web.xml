<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <display-name>Web-BasedTransportationSystem</display-name>

  <!-- Force UTF-8 -->
  <filter>
    <filter-name>EncodingFilter</filter-name>
    <filter-class>com.example.filters.EncodingFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>EncodingFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <!-- (Optional) Auth filter you’ll implement later to protect /profile, /book, etc. -->
  <!--
  <filter>
    <filter-name>AuthFilter</filter-name>
    <filter-class>com.example.filters.AuthFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/secure/*</url-pattern>
  </filter-mapping>
  -->
  <!-- Require session for these paths -->
  <filter>
    <filter-name>AuthFilter</filter-name>
    <filter-class>com.example.filters.AuthFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/profile</url-pattern>
  </filter-mapping>
  <!-- Add more patterns as you add secure pages -->
  <!--
  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/book</url-pattern>
  </filter-mapping>
  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/rides/*</url-pattern>
  </filter-mapping>
  -->
  <!-- Prevent caching for protected pages -->
  <filter>
    <filter-name>NoCacheFilter</filter-name>
    <filter-class>com.example.filters.NoCacheFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>NoCacheFilter</filter-name>
    <url-pattern>/profile</url-pattern>
  </filter-mapping>



  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>
</web-app>
